{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "iftm",
  "compatibility_date": "2025-07-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "NEXTJS_ENV": "production"
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "iftm2"
    }
  ]
}
